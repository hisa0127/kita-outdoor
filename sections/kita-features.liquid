<section class="kita-features">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="kita-features__heading animate-fade-up">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subtext != blank -%}
      <p class="kita-features__subtext animate-fade-up">{{ section.settings.subtext }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="kita-features__grid" role="list">
        {%- for block in section.blocks -%}
          <li class="kita-features__item animate-fade-up" style="transition-delay: {{ forloop.index0 | times: 120 }}ms" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank -%}
              <div class="kita-features__icon">{{ block.settings.icon }}</div>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <h3 class="kita-features__item-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="kita-features__item-desc">{{ block.settings.description }}</p>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.kita-features {
  padding: 8rem 0;
}

.kita-features__heading {
  font-size: clamp(2.8rem, 4vw, 4rem);
  font-weight: 700;
  text-align: center;
  margin: 0 0 1.6rem;
  letter-spacing: 0.05em;
}

.kita-features__subtext {
  font-size: 1.6rem;
  text-align: center;
  opacity: 0.7;
  max-width: 60rem;
  margin: 0 auto 6rem;
  line-height: 1.8;
}

.kita-features__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 4rem;
  list-style: none;
  margin: 0;
  padding: 0;
}

.kita-features__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 4rem 2.4rem;
  border-radius: 8px;
  background-color: rgba(var(--kita-green-rgb), 0.04);
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}

.kita-features__item:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
}

.kita-features__icon {
  font-size: 4.8rem;
  margin-bottom: 2.4rem;
  line-height: 1;
}

.kita-features__item-title {
  font-size: 2rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  margin: 0 0 1.2rem;
  color: var(--kita-green);
}

.kita-features__item-desc {
  font-size: 1.5rem;
  line-height: 1.8;
  opacity: 0.75;
  margin: 0;
}

@media screen and (max-width: 989px) {
  .kita-features__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 2.4rem;
  }
}

@media screen and (max-width: 749px) {
  .kita-features {
    padding: 6rem 0;
  }
  .kita-features__grid {
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  .kita-features__item {
    padding: 3.2rem 2rem;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "KITAこだわりポイント",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "セクション見出し",
      "default": "KITA OUTDOORのこだわり"
