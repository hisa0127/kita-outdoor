    {
      "type": "textarea",
      "id": "subtext",
      "label": "サブテキスト",
      "default": "北の大地で培った職人の技と、アウトドアへの深い愛情から生まれた道具たち。"
    },
  ],
  "blocks": [
    {
      "type": "feature_item",
      "name": "こだわりポイント",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "アイコン（絵文字）",
          "default": "🏔️"
        },
        {
          "type": "text",
          "id": "title",
          "label": "タイトル",
          "default": "過酷な環境でテスト済み"
        },
        {
          "type": "textarea",
          "id": "description",
