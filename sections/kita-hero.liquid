<section
  class="kita-hero kita-hero--align-{{ section.settings.text_align }}"
  style="
    {% if section.settings.bg_image != blank %}
      background-image: url('{{ section.settings.bg_image | image_url: width: 1920 }}');
    {% else %}
      background-color: {{ section.settings.bg_color }};
    {% endif %}
    min-height: {{ section.settings.min_height }}vh;
    color: {{ section.settings.text_color }};
  "
>
  <div
    class="kita-hero__overlay"
    style="background-color: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});"
  ></div>

  <div class="kita-hero__inner page-width">
    {%- if section.settings.eyebrow != blank -%}
      <p class="kita-hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="kita-hero__heading">{{ section.settings.heading | newline_to_br | strip_newlines }}</h1>
    {%- endif -%}
    {%- if section.settings.subtext != blank -%}
      <p class="kita-hero__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a
        href="{{ section.settings.button_url | default: '#' }}"
        class="kita-hero__btn button"
      >
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.kita-hero {
  position: relative;
  display: flex;
  align-items: center;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
}

.kita-hero__overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.kita-hero__inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 2.4rem;
  padding-top: 8rem;
  padding-bottom: 8rem;
}

/* テキスト配置：左寄せ（デフォルト） */
.kita-hero--align-left .kita-hero__inner {
  align-items: flex-start;
  text-align: left;
}

/* テキスト配置：中央揃え */
.kita-hero--align-center .kita-hero__inner {
  align-items: center;
  text-align: center;
}

.kita-hero__eyebrow {
  font-size: 1.3rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  opacity: 0.8;
  margin: 0;
}

.kita-hero__heading {
  font-size: clamp(3.6rem, 6vw, 7.2rem);
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: 0.03em;
  margin: 0;
}

/* PC: brタグを非表示にして自然な1行表示 */
.kita-hero__heading br { display: none; }

/* SP: brタグを表示して意図した位置で改行 */
@media screen and (max-width: 749px) {
  .kita-hero__heading br { display: inline; }
}

.kita-hero__subtext {
  font-size: clamp(1.5rem, 2vw, 1.8rem);
  line-height: 1.8;
  opacity: 0.9;
  max-width: 52rem;
  margin: 0;
}

.kita-hero__btn {
  margin-top: 0.8rem;
  padding: 1.6rem 4rem;
  font-size: 1.5rem;
  letter-spacing: 0.08em;
  border-radius: 4px;
  background-color: var(--kita-green);
  color: #ffffff;
  border-color: var(--kita-green);
  text-decoration: none;
}

.kita-hero__btn:hover {
  background-color: #143326;
  border-color: #143326;
}

@media screen and (max-width: 749px) {
  .kita-hero__inner {
    align-items: center;
    text-align: center;
    padding-top: 6rem;
    padding-bottom: 6rem;
  }
  .kita-hero__subtext {
    max-width: 100%;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "KITAヒーロー",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "背景画像（設定するとbg_colorより優先）"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "背景色（画像未設定時に使用）",
      "default": "#1B4332"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "セクションの高さ",
      "default": 85
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "オーバーレイの濃さ",
      "default": 35
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "テキスト配置",
      "options": [
        { "value": "left", "label": "左寄せ" },
        { "value": "center", "label": "中央揃え" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "サブタイトル（小文字）",
      "default": "KITA OUTDOOR"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "キャッチコピー（SPで改行したい位置でEnterキーを押す）",
      "default": "山と森で、\n自分を更新する"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "サブテキスト",
      "default": "過酷な環境で生まれたギアは、あなたの冒険を支える。\nKITA OUTDOORが届ける、本物の道具。"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "CTAボタンのテキスト",
      "default": "コレクションを見る"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "CTAボタンのリンク先"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "テキストカラー",
      "options": [
        { "value": "#ffffff", "label": "ホワイト" },
        { "value": "#1A1A1A", "label": "ダーク" }
      ],
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "KITAヒーロー"
    }
  ]
}
{% endschema %}
