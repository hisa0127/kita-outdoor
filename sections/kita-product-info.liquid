<section class="kita-product-info">
  <div class="page-width">

    {%- if section.settings.brand_comment != blank -%}
      <div class="kita-product-info__comment">
        <p class="kita-product-info__comment-text">{{ section.settings.brand_comment }}</p>
      </div>
    {%- endif -%}

    {%- if section.settings.spec_material != blank
      or section.settings.spec_weight != blank
      or section.settings.spec_season != blank -%}
      <div class="kita-product-info__specs">
        {%- if section.settings.spec_material != blank -%}
          <div class="kita-product-info__spec-item">
            <span class="kita-product-info__spec-label">素材</span>
            <span class="kita-product-info__spec-value">{{ section.settings.spec_material }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.spec_weight != blank -%}
          <div class="kita-product-info__spec-item">
            <span class="kita-product-info__spec-label">重量</span>
            <span class="kita-product-info__spec-value">{{ section.settings.spec_weight }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.spec_season != blank -%}
          <div class="kita-product-info__spec-item">
            <span class="kita-product-info__spec-label">対応シーズン</span>
            <span class="kita-product-info__spec-value">{{ section.settings.spec_season }}</span>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
.kita-product-info {
  padding: 4.8rem 0;
  border-top: 1px solid rgba(var(--kita-green-rgb), 0.15);
}

/* こだわりコメント */
.kita-product-info__comment {
  margin-bottom: 4rem;
  padding: 2.4rem 3.2rem;
  border-left: 4px solid var(--kita-green);
  background-color: rgba(var(--kita-green-rgb), 0.04);
  border-radius: 0 4px 4px 0;
}

.kita-product-info__comment-text {
  font-size: 1.6rem;
  line-height: 1.9;
  color: var(--kita-text);
  margin: 0;
}

/* スペック3列 */
.kita-product-info__specs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.6rem;
}

.kita-product-info__spec-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 2.4rem 1.6rem;
  border: 1px solid rgba(var(--kita-green-rgb), 0.2);
  border-radius: 6px;
  gap: 1rem;
}

.kita-product-info__spec-label {
  font-size: 1.2rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--kita-green);
  background-color: rgba(var(--kita-green-rgb), 0.08);
  padding: 0.4rem 1.2rem;
  border-radius: 2rem;
}

.kita-product-info__spec-value {
  font-size: 1.5rem;
  line-height: 1.6;
  color: var(--kita-text);
  font-weight: 500;
}

@media screen and (max-width: 749px) {
  .kita-product-info {
    padding: 3.2rem 0;
  }
  .kita-product-info__specs {
    grid-template-columns: 1fr;
    gap: 1.2rem;
  }
  .kita-product-info__comment {
    padding: 2rem 2rem;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "KITA商品詳細情報",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "textarea",
      "id": "brand_comment",
      "label": "ブランドのこだわりコメント",
      "default": "北の山岳地帯で実際にフィールドテストを重ね、過酷な環境でも機能することを確認した本物の道具です。職人の手によって丁寧に仕上げられた一着を、あなたの冒険に。"
    },
    {
      "type": "text",
      "id": "spec_material",
      "label": "素材",
      "default": "リサイクルナイロン100%"
    },
    {
      "type": "text",
      "id": "spec_weight",
      "label": "重量",
      "default": "約350g"
    },
    {
      "type": "text",
      "id": "spec_season",
      "label": "対応シーズン",
      "default": "春・夏・秋"
    }
  ],
  "presets": [
    {
      "name": "KITA商品詳細情報"
    }
  ]
}
{% endschema %}
