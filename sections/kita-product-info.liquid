<section class="kita-product-info">
  <div class="page-width">

    {%- if section.settings.heading != blank -%}
      <h2 class="kita-product-info__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <dl class="kita-product-info__list">
        {%- for block in section.blocks -%}
          {%- case block.type -%}

          {%- when 'highlight' -%}
            <div class="kita-product-info__item kita-product-info__item--highlight" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}
                <span class="kita-product-info__icon">{{ block.settings.icon }}</span>
              {%- endif -%}
              <div class="kita-product-info__item-body">
                {%- if block.settings.title != blank -%}
                  <dt class="kita-product-info__item-title">{{ block.settings.title }}</dt>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <dd class="kita-product-info__item-desc">{{ block.settings.description }}</dd>
                {%- endif -%}
              </div>
            </div>

          {%- when 'spec' -%}
            <div class="kita-product-info__item kita-product-info__item--spec" {{ block.shopify_attributes }}>
              {%- if block.settings.label != blank -%}
                <dt class="kita-product-info__spec-label">{{ block.settings.label }}</dt>
              {%- endif -%}
              {%- if block.settings.value != blank -%}
                <dd class="kita-product-info__spec-value">{{ block.settings.value }}</dd>
              {%- endif -%}
            </div>

          {%- endcase -%}
        {%- endfor -%}
      </dl>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
.kita-product-info {
  padding: 6.4rem 0;
  border-top: 1px solid rgba(var(--kita-green-rgb), 0.15);
}

.kita-product-info__heading {
  font-size: clamp(2rem, 3vw, 2.8rem);
  font-weight: 700;
  letter-spacing: 0.05em;
  color: var(--kita-green);
  margin: 0 0 4rem;
  padding-bottom: 1.6rem;
  border-bottom: 2px solid var(--kita-green);
  display: inline-block;
}

.kita-product-info__list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* ハイライトブロック */
.kita-product-info__item--highlight {
  display: flex;
  align-items: flex-start;
  gap: 2rem;
  padding: 2.4rem 0;
  border-bottom: 1px solid rgba(var(--kita-green-rgb), 0.1);
}

.kita-product-info__item--highlight:last-of-type {
  border-bottom: none;
}

.kita-product-info__icon {
  font-size: 3.2rem;
  line-height: 1;
  flex-shrink: 0;
  width: 4.8rem;
  text-align: center;
}

.kita-product-info__item-body {
  flex: 1;
}

.kita-product-info__item-title {
  font-size: 1.7rem;
  font-weight: 700;
  color: var(--kita-green);
  letter-spacing: 0.04em;
  margin: 0 0 0.8rem;
}

.kita-product-info__item-desc {
  font-size: 1.5rem;
  line-height: 1.8;
  color: var(--kita-text);
  opacity: 0.8;
  margin: 0;
}

/* スペックブロック */
.kita-product-info__item--spec {
  display: grid;
  grid-template-columns: 16rem 1fr;
  gap: 0;
  padding: 1.6rem 0;
  border-bottom: 1px solid rgba(var(--kita-green-rgb), 0.1);
}

.kita-product-info__spec-label {
  font-size: 1.4rem;
  font-weight: 600;
  color: var(--kita-green);
  letter-spacing: 0.04em;
  background-color: rgba(var(--kita-green-rgb), 0.06);
  padding: 0.8rem 1.2rem;
  display: flex;
  align-items: center;
}

.kita-product-info__spec-value {
  font-size: 1.5rem;
  color: var(--kita-text);
  padding: 0.8rem 1.6rem;
  display: flex;
  align-items: center;
  margin: 0;
}

@media screen and (max-width: 749px) {
  .kita-product-info {
    padding: 4.8rem 0;
  }
  .kita-product-info__item--spec {
    grid-template-columns: 1fr;
  }
  .kita-product-info__spec-label {
    border-bottom: 1px solid rgba(var(--kita-green-rgb), 0.1);
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "KITA商品詳細情報",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "セクション見出し",
      "default": "商品の特徴・スペック"
    }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "商品ハイライト",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "アイコン（絵文字）",
          "default": "🏔️"
        },
        {
          "type": "text",
          "id": "title",
          "label": "タイトル",
          "default": "耐水圧20,000mm"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "説明文",
          "default": "本格的な登山にも対応できる高耐水圧設計。突然の豪雨でも快適さを保ちます。"
        }
      ]
    },
    {
      "type": "spec",
      "name": "スペック",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "項目名",
          "default": "素材"
        },
        {
          "type": "text",
          "id": "value",
          "label": "内容",
          "default": "ナイロン100%（リサイクル素材使用）"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KITA商品詳細情報",
      "blocks": [
        {
          "type": "highlight",
          "settings": {
            "icon": "💧",
