<section
  class="kita-collection-banner"
  style="
    {% if section.settings.bg_image != blank %}
      background-image: url('{{ section.settings.bg_image | image_url: width: 1920 }}');
    {% elsif collection.image != blank %}
      background-image: url('{{ collection.image | image_url: width: 1920 }}');
    {% else %}
      background-color: {{ section.settings.bg_color }};
    {% endif %}
    min-height: {{ section.settings.min_height }}rem;
    color: {{ section.settings.text_color }};
  "
>
  <div
    class="kita-collection-banner__overlay"
    style="background-color: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});"
  ></div>
  <div class="kita-collection-banner__inner page-width">
    <p class="kita-collection-banner__eyebrow">COLLECTION</p>
    <h1 class="kita-collection-banner__title">{{ collection.title }}</h1>
    {%- if collection.description != blank and section.settings.show_description -%}
      <p class="kita-collection-banner__desc">{{ collection.description }}</p>
    {%- endif -%}
    <p class="kita-collection-banner__count">{{ collection.products_count }}点の商品</p>
  </div>
</section>

{% stylesheet %}
.kita-collection-banner {
  position: relative;
  display: flex;
  align-items: center;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
}

.kita-collection-banner__overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.kita-collection-banner__inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 1.6rem;
  padding-top: 6.4rem;
  padding-bottom: 6.4rem;
}

.kita-collection-banner__eyebrow {
  font-size: 1.2rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  opacity: 0.7;
  margin: 0;
}

.kita-collection-banner__title {
  font-size: clamp(3.2rem, 5vw, 5.6rem);
  font-weight: 700;
  letter-spacing: 0.05em;
  line-height: 1.2;
  margin: 0;
}

.kita-collection-banner__desc {
  font-size: 1.6rem;
  line-height: 1.8;
  opacity: 0.85;
  max-width: 56rem;
  margin: 0;
}

.kita-collection-banner__count {
  font-size: 1.3rem;
  letter-spacing: 0.1em;
  opacity: 0.6;
  margin: 0;
  border-top: 1px solid currentColor;
  padding-top: 1.6rem;
  width: fit-content;
}

@media screen and (max-width: 749px) {
  .kita-collection-banner__inner {
    padding-top: 4.8rem;
    padding-bottom: 4.8rem;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "KITAコレクションバナー",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "コレクション画像が設定されている場合は自動で背景に使用されます。手動で上書きしたい場合は下記から設定してください。"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "背景画像（手動設定・コレクション画像より優先）"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "背景色（画像なしの場合）",
      "default": "#1B4332"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "rem",
      "label": "バナーの高さ",
      "default": 35
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "オーバーレイの濃さ",
      "default": 40
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "テキストカラー",
      "options": [
        { "value": "#ffffff", "label": "ホワイト" },
        { "value": "#1A1A1A", "label": "ダーク" }
      ],
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "コレクションの説明文を表示する",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "KITAコレクションバナー"
    }
  ]
}
{% endschema %}
