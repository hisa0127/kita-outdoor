<section class="kita-cta-banner" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
  <div class="kita-cta-banner__inner page-width">
    {%- if section.settings.eyebrow != blank -%}
      <p class="kita-cta-banner__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="kita-cta-banner__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subtext != blank -%}
      <p class="kita-cta-banner__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a
        href="{{ section.settings.button_url | default: '#' }}"
        class="kita-cta-banner__btn"
        style="background-color: {{ section.settings.btn_color }}; color: {{ section.settings.btn_text_color }};"
      >
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.kita-cta-banner {
  padding: 9.6rem 0;
  text-align: center;
}

.kita-cta-banner__inner {
  max-width: 72rem;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2.4rem;
}

.kita-cta-banner__eyebrow {
  font-size: 1.3rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  opacity: 0.7;
  margin: 0;
}

.kita-cta-banner__heading {
  font-size: clamp(3.2rem, 5vw, 5.2rem);
  font-weight: 700;
  line-height: 1.25;
  letter-spacing: 0.04em;
  margin: 0;
}

.kita-cta-banner__subtext {
  font-size: 1.6rem;
  line-height: 1.8;
  opacity: 0.85;
  margin: 0;
  max-width: 55rem;
}

.kita-cta-banner__btn {
  display: inline-block;
  padding: 1.8rem 5.6rem;
  font-size: 1.5rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-decoration: none;
  border-radius: 4px;
  transition: opacity 0.2s ease, transform 0.2s ease;
  margin-top: 0.8rem;
}

.kita-cta-banner__btn:hover {
  opacity: 0.85;
  transform: translateY(-2px);
}

@media screen and (max-width: 749px) {
  .kita-cta-banner {
    padding: 7.2rem 0;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "KITAバナーCTA",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "サブタイトル（小文字）",
      "default": "COLLECTION"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "あなたの次の冒険を、\nここから始めよう。"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "サブテキスト",
      "default": "KITA OUTDOORが厳選した道具で、自然と向き合う時間をもっと豊かに。"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "ボタンのテキスト",
      "default": "コレクションをすべて見る"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "ボタンのリンク先"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "背景色",
      "default": "#1B4332"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "テキストカラー",
      "default": "#F8F4EF"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "ボタン背景色",
      "default": "#F8F4EF"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "ボタンのテキストカラー",
      "default": "#1B4332"
    }
  ],
  "presets": [
    {
      "name": "KITAバナーCTA"
    }
  ]
}
{% endschema %}
